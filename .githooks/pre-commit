#!/bin/sh
set -eu

# Byte-compile init and local lisp before allowing commit.
# This does NOT stage or commit any .elc files.

# Emacs binary resolution order:
# 1) EMACS_BIN env var
# 2) git config core.hookEmacs
# 3) "emacs" (PATH)
EMACS_BIN=${EMACS_BIN:-"$(git config --get core.hookEmacs 2>/dev/null || true)"}
EMACS_BIN=${EMACS_BIN:-emacs}

if [ -x "$EMACS_BIN" ]; then
  :
elif EMACS_PATH=$(command -v -- "$EMACS_BIN" 2>/dev/null); then
  EMACS_BIN=$EMACS_PATH
else
  echo "Skipping hook byte-compilation: Emacs binary not found: $EMACS_BIN" >&2
  exit 0
fi

EMACSDIR=$(git rev-parse --show-toplevel)
LISPDIR="$EMACSDIR/lisp"
COMPILE_INIT="$EMACSDIR/.githooks/compile-init.el"

FILES=""
[ -f "$EMACSDIR/init.el" ] && FILES="$FILES $EMACSDIR/init.el"
[ -f "$EMACSDIR/early-init.el" ] && FILES="$FILES $EMACSDIR/early-init.el"

if [ -d "$LISPDIR" ]; then
  # Only compile *.el directly under ./lisp (non-recursive)
  for f in "$LISPDIR"/*.el; do
    [ -e "$f" ] || continue
    FILES="$FILES $f"
  done
fi

# Nothing to do
if [ -z "$(printf %s "$FILES" | tr -d ' ')" ]; then
  exit 0
fi

"$EMACS_BIN" -Q --batch \
  -l "$COMPILE_INIT" \
  --eval "(setq byte-compile-warnings '(not obsolete))" \
  -f batch-byte-compile \
  $FILES
